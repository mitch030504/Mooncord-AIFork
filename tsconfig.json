{
  "compilerOptions": {
    "outDir": "./dist/",
    "target": "es2024",
    "lib": ["es2024"],
    "module": "node16",
    "moduleResolution": "node16",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}